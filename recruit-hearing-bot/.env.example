# ===== Supabase (会話状態・メッセージの永続化) =====
# 任意。未設定の場合は「インメモリ（仮）」で動作します（サーバ再起動でデータは消えます）。
# 永続化したい場合のみ両方を設定してください。
# NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===== Google Gemini (AI深掘り質問の生成) =====
# 未設定でも動作します（その場合AI深掘りはスキップされ、固定フローのみ進行）
GEMINI_API_KEY=your-gemini-api-key
# 省略時は gemini-2.5-flash
GEMINI_MODEL=gemini-2.5-flash

# ===== AI 呼び出し（タイムアウト。すべて任意。値は既定値） =====
# AI_TIMEOUT_MS=10000            # AI全体の既定タイムアウト
# AI_TIMEOUT_CLASSIFY_MS=5000    # 分類
# AI_TIMEOUT_ANSWER_MS=10000     # ナレッジ回答
# AI_TIMEOUT_DEEPEN_MS=12000     # 深掘り（十分性判定）
# AI_TIMEOUT_ASSIST_MS=10000     # 「わからない」時の提案生成
# AI_TIMEOUT_GAPFILL_MS=15000    # 終盤の観点補完（生成質問）

# ===== サーキットブレーカ（連続失敗時にAIを一時遮断。任意） =====
# AI_FAIL_THRESHOLD=3            # 遮断に至る失敗回数
# AI_FAIL_WINDOW_MS=60000        # 失敗カウントの対象期間
# AI_COOLDOWN_MS=90000           # 遮断時間
# AI_NETWORK_FAIL_THRESHOLD=2    # ネットワーク障害がこの回数で全AIを即遮断→固定質問へフォールバック
# AI_MAX_BACKOFF_MS=3600000      # 429のretry-after等を尊重する際のバックオフ上限（既定1時間）
# AI_SLOW_MS=6000                # 低速ログのしきい値
# AI_LOG_LEVEL=warn              # off / error / warn / info / debug

# ===== 分類（ベクトル判定。任意） =====
# CLASSIFY_MODE=ai              # ai=毎ターン必ずAIで分類 / hybrid=曖昧時のみAI（速度優先）
# CLASSIFY_WEAK_MAXLEN=40        # 弱い疑問詞シグナルを質問候補として扱う最大文字数

# ===== 深掘り・観点補完（続行はAI主導。下記は暴走防止の安全上限。任意） =====
# AI_DEEPEN_MAX_ROUNDS=3         # 深掘りの安全上限往復数（掘るかはAIの十分性判断。0で深掘り無効）
# AI_GAPFILL_MAX_QUESTIONS=4     # 終盤の観点補完の安全上限（続行はAIのcovered/balanced判断。0で無効）

# ===== 早期ラップアップ（AI主導の終了分岐。任意） =====
# AI_WRAPUP_ENABLED=true         # 全体が十分ならAI判断で残り質問を省いて締める（falseで無効）
# AI_WRAPUP_MIN_SLOTS=5          # 早すぎる終了を防ぐため、最低この件数を回答してから判定
# AI_TIMEOUT_WRAPUP_MS=8000      # ラップアップ判定のタイムアウト

# ===== 観点バランス計算（coverage。AI不使用の数式パラメータ。任意） =====
# COVERAGE_LEN_SCALE=60          # 文字量スコアの飽和スケール（chars=K で0.5）
# COVERAGE_SUFF_WEIGHT=0.6       # 十分性スコアの重み（残りが文字量の重み）
# COVERAGE_GAP_THRESHOLD=0.5     # これ未満を「取りこぼし」とみなす
# COVERAGE_EVENNESS_MIN=0.85     # 「均等」とみなす evenness 下限

# ===== フェーズ別モデル上書き（未設定なら GEMINI_MODEL を使用。任意） =====
# AI_CLASSIFY_MODEL=
# AI_ANSWER_MODEL=
# AI_DEEPEN_MODEL=
# AI_ASSIST_MODEL=
# AI_GAPFILL_MODEL=
